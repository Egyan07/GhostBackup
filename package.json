{
  "name": "ghostbackup",
  "version": "1.0.0",
  "description": "SharePoint daily auto-backup system for Red Parrot Accounting",
  "author": "Egyan <egyan@redparrot.co.uk>",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite --port 3000",
    "dev:electron": "wait-on http://localhost:3000 && set NODE_ENV=development && electron .",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.0.0",
    "vite": "^5.3.1",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.redparrot.ghostbackup",
    "productName": "GhostBackup",
    "copyright": "Red Parrot Accounting",
    "icon": "assets/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/**/*",
      "config/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to":   "backend",
        "filter": ["**/*"]
      },
      {
        "from": "config",
        "to":   "config",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon":   "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon":   "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick":             false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":        "assets/icon.ico",
      "installerHeaderIcon":  "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName":         "GhostBackup"
    }
  }
}
